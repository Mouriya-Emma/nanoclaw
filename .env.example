# Mattermost (set both to enable)
# MATTERMOST_URL=https://your-mattermost-instance.com
# MATTERMOST_BOT_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ONLY=

# Comma-separated list of host CLI commands that container agents can execute
# via the proxy. Each command gets a stub script in /opt/host-exec/.
HOST_EXEC_ALLOWLIST=fulcrum
