{
  "name": "nanoclaw",
  "version": "1.2.42",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config e2e/vitest.workspace.ts",
    "test:e2e:commands": "vitest run --config e2e/vitest.workspace.ts --project commands",
    "test:e2e:flow": "vitest run --config e2e/vitest.workspace.ts --project message-flow",
    "test:e2e:mcp": "vitest run --config e2e/vitest.workspace.ts --project mcp-tools",
    "test:e2e:coding": "vitest run --config e2e/vitest.workspace.ts --project coding",
    "test:e2e:ipc": "vitest run --config e2e/vitest.workspace.ts --project ipc-tools",
    "test:e2e:hostexec": "vitest run --config e2e/vitest.workspace.ts --project host-exec",
    "test:e2e:session": "vitest run --config e2e/vitest.workspace.ts --project session",
    "test:e2e:mm": "vitest run --config e2e/vitest.workspace.ts --project mm-commands --project mm-message-flow --project mm-coding --project mm-ipc-tools --project mm-session",
    "test:e2e:mm:commands": "vitest run --config e2e/vitest.workspace.ts --project mm-commands",
    "test:e2e:mm:flow": "vitest run --config e2e/vitest.workspace.ts --project mm-message-flow",
    "test:e2e:mm:coding": "vitest run --config e2e/vitest.workspace.ts --project mm-coding",
    "test:e2e:mm:ipc": "vitest run --config e2e/vitest.workspace.ts --project mm-ipc-tools",
    "test:e2e:mm:session": "vitest run --config e2e/vitest.workspace.ts --project mm-session",
    "e2e:auth": "tsx e2e/auth.ts"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.55.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "grammy": "^1.41.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "telegram": "^2.26.22",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
